# pyenv
#   For a library or package, you might want to share your .python-version.
#   For an app, this can be ignored:
# .python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if you used --three or --two, pipenv may create many files.
# .env

# poetry
#   poetry.lock is recommended to be checked in, but virtual environments are not.
#   Usually, virtual environments are created in Poetry's cache folder.
#   If you configured to create it locally:
.venv/
venv/
ENV/
env/

